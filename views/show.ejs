<% layout("layouts/boilerplate") %>
<div class="container_card">
    <div class="card">


<h1><%= blog.title %></h1>

<hr>

<p class="blog_content"><%= blog.content %></p>
<% if (currUser && blog.author.equals(currUser._id)) { %>
<a href="/blogs/<%= blog._id %>/edit">
    <button class="button">Edit Blog</button>
</a>
<% } %>

<a href="/blogs">Back to All Blogs</a>

</div>
</div>