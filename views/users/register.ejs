<h1>Register</h1>

<form action="/register" method="POST">

    <div>
        <label>Username</label>
        <input
            type="text"
            name="username"
            required
        >
    </div>

    <br>

    <div>
        <label>Password</label>
        <input
            type="password"
            name="password"
            required
        >
    </div>

    <br>

    <button>Register</button>

</form>